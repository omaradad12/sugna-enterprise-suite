# Copy to .env and fill in values. Do not commit .env to version control.

# Required in production
#
# Example (generate your own before deploying):
DJANGO_SECRET_KEY=change-me-please-generate-a-real-secret
DEBUG=false
ALLOWED_HOSTS=yourdomain.com,.yourdomain.com,localhost

# When DEBUG=true, tenant DBs auto-migrate on first request that needs new schema (local dev).
# Set to false to force manual: python manage.py migrate_tenant --tenant <slug>
# TENANT_AUTO_MIGRATE=false

# Database (used by Django and docker-compose db service)
DB_NAME=sugna_enterprise_suite
DB_USER=postgres
DB_PASSWORD=change-me-please
DB_HOST=localhost
DB_PORT=5432

# Optional (recommended for production): disable extra dev tenant DBs (wardi, hurdo)
DB_EXTRA_TENANTS=false

# Required for HTTPS if auto-derivation from ALLOWED_HOSTS is not enough (wildcards, extra domains).
# If unset, production builds https://<host> for each non-wildcard ALLOWED_HOSTS entry.
# CSRF_TRUSTED_ORIGINS=https://app.yourdomain.com,https://yourdomain.com

# Optional: static/media paths (defaults work with Docker volumes)
# STATIC_ROOT=/app/staticfiles
# MEDIA_ROOT=/app/media

# Optional: security hardening flags (applied when DEBUG=false)
# SECURE_SSL_REDIRECT=true
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=true
# SECURE_HSTS_PRELOAD=false
