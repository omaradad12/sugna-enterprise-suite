# Copy to .env and fill in values. Do not commit .env to version control.

# Required in production
DJANGO_SECRET_KEY=your-secret-key-at-least-50-chars
DEBUG=false
ALLOWED_HOSTS=yourdomain.com,.yourdomain.com,localhost

# Database (used by Django and docker-compose db service)
DB_NAME=sugna_enterprise_suite
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_HOST=localhost
DB_PORT=5432

# Optional: disable extra dev tenant DBs (wardi, hurdo) in production
# DB_EXTRA_TENANTS=false

# Optional: HTTPS origins for CSRF (comma-separated)
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Optional: static/media paths (defaults work with Docker volumes)
# STATIC_ROOT=/app/staticfiles
# MEDIA_ROOT=/app/media
