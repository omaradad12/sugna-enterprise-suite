# Development environment
# Copy to .env when using Docker for dev, or load this file when running runserver locally.
# Do not use these values in production.

DJANGO_SECRET_KEY=django-insecure-dev-only-change-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,*

DB_NAME=sugna_enterprise_suite
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Optional: enable extra dev tenant DBs (wardi, hurdo)
# DB_EXTRA_TENANTS=true
